# Copy this file to .env and fill in the keys for whatever you want to use.
# Only GOOGLE_API_KEY is required; everything else auto-enables its tool.

# ── Required ──────────────────────────────────────────────────────────────────
# Google AI Studio — the LLM backend.  Get one at https://aistudio.google.com
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# ── Optional tools ────────────────────────────────────────────────────────────
# Each key below enables its corresponding tool.  Leave blank / unset to skip.

# Web search via Tavily — https://tavily.com (1000 searches/month free)
# See assistant/tools/search/README.md
TAVILY_API_KEY=

# Pin a preferred search backend when multiple are configured.
# Valid values today: tavily   (leave blank to auto-pick the first configured)
SEARCH_PROVIDER=

# Discord — both are optional and register independently.
# See assistant/tools/discord/README.md for setup and required bot intents.
DISCORD_WEBHOOK_URL=         # enables send_discord_message (write, ~1 min)
DISCORD_BOT_TOKEN=           # enables read_discord_messages (read, ~5 min)
DISCORD_CHANNEL_ID=          # optional — else derived from the webhook URL

# Gmail uses OAuth2, not an env key — see assistant/tools/gmail/README.md

# Local file writes — point this at a dedicated notes folder (NOT your home dir).
# See assistant/tools/local_files/README.md
LOCAL_FILES_DIR=             # e.g. ~/Documents/assistant-notes
